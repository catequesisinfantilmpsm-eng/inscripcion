<script>
// ══════════════════════════════════════════════════════════════
//  ⚠️  CONFIGURA ESTA URL CON TU WEB APP DE APPS SCRIPT
//  Después de desplegar: Apps Script → Implementar → Web App
//  Copia la URL que termina en /exec y pégala aquí:
// ══════════════════════════════════════════════════════════════
var API_URL = 'https://script.google.com/macros/s/REEMPLAZA_CON_TU_URL/exec';

// ══ ESTADO GLOBAL ══════════════════════════════════════════════
var S = {
  alumno   : null,   // alumno actual
  archivos : {},     // { foto, actaNac, boletaBautizo, boletaConf, comprobantePago }
  fotoB64  : null,
  registros: [],
  step     : 1,
  qrDatos  : null,
  codRenov : null
};

// ══ NAVEGACIÓN ══════════════════════════════════════════════════
function goPage(id) {
  document.querySelectorAll('.pg').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.nb,.bt').forEach(b => b.classList.toggle('on', b.dataset.pg === id));
  var el = document.getElementById('pg-' + id);
  if (el) el.classList.add('on');
  if (id === 'admin' && S.registros.length === 0) cargarAdmin();
  if (id === 'inicio') actualizarStats(S.registros);
}
document.querySelectorAll('.nb,.bt').forEach(b => b.addEventListener('click', () => goPage(b.dataset.pg)));

// ══ UI HELPERS ══════════════════════════════════════════════════
function showLoad(msg){ document.getElementById('lmsg').textContent = msg||'Procesando…'; document.getElementById('loader').classList.add('on'); }
function hideLoad(){ document.getElementById('loader').classList.remove('on'); }
function toast(msg, t){
  t = t||'inf';
  var el = document.createElement('div');
  el.className = 'toast t'+t;
  el.textContent = msg;
  document.getElementById('tc').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}
function openMo(id){ document.getElementById(id).classList.add('on'); }
function closeMo(id){ document.getElementById(id).classList.remove('on'); }
document.querySelectorAll('.mo').forEach(m => m.addEventListener('click', e => { if(e.target===m) m.classList.remove('on'); }));

// ══ API ══════════════════════════════════════════════════════════
var API = {
  get: async function(action, params){
    params = params || {};
    var qs = new URLSearchParams(Object.assign({action}, params)).toString();
    try {
      var r = await fetch(API_URL + (API_URL.includes('?')?'&':'?') + qs, {method:'GET',redirect:'follow'});
      return await r.json();
    } catch(e){ return {ok:false, msg:e.message}; }
  },
  post: async function(action, payload){
    payload = payload || {};
    payload.action = action;
    try {
      var r = await fetch(API_URL, {method:'POST',redirect:'follow',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      return await r.json();
    } catch(e){ return {ok:false, msg:'Error de conexión: '+e.message}; }
  },
  subirTodos: async function(archivos, folio){
    var links = {};
    var mapC = {foto:'Fotos',actaNac:'ActasNacimiento',boletaBautizo:'BoletasBautizo',boletaConf:'BoletasConfirmacion',comprobantePago:'ComprobantesPago'};
    for (var campo in archivos) {
      var arc = archivos[campo];
      if (!arc || !arc.base64) continue;
      try {
        showLoad('Subiendo '+arc.nombre+'…');
        var resp = await API.post('subirArchivo',{base64:arc.base64,nombre:arc.nombre,mimeType:arc.mimeType,carpeta:mapC[campo]||'Otros',folio:folio||''});
        if (resp.ok) links[campo] = resp.directUrl || resp.enlace || '';
      } catch(e){ console.warn('Error subiendo '+campo,e); }
    }
    return links;
  }
};

// ══ HELPERS ══════════════════════════════════════════════════════
function calcEdad(f){ if(!f)return''; var h=new Date(),n=new Date(f); if(isNaN(n))return''; var e=h.getFullYear()-n.getFullYear(),m=h.getMonth()-n.getMonth(); if(m<0||(m===0&&h.getDate()<n.getDate()))e--; return e; }
function fmtFecha(s){ if(!s)return''; var d=new Date(s+'T00:00:00'); return isNaN(d)?s:d.toLocaleDateString('es-MX',{day:'2-digit',month:'2-digit',year:'numeric'}); }
function ciclo(){ var a=new Date().getFullYear(),m=new Date().getMonth()+1; return m>=9?a+'-'+(a+1):(a-1)+'-'+a; }
function fileToB64(file){ return new Promise((res,rej)=>{ var r=new FileReader(); r.onload=e=>res(e.target.result.split(',')[1]); r.onerror=()=>rej(r.error); r.readAsDataURL(file); }); }

// ══ CÁMARA ════════════════════════════════════════════════════════
var _stream = null;

window.addEventListener('load', function(){
  // Listener galería
  var inpG = document.getElementById('inpGaleria');
  if(inpG) inpG.addEventListener('change', function(e){
    var f = e.target.files && e.target.files[0];
    if(!f) return;
    if(!f.type.startsWith('image/')){ toast('Selecciona una imagen','err'); return; }
    leerImagen(f);
  });

  // Listener fecha → edad
  var fd = document.getElementById('fFechaNac');
  if(fd) fd.addEventListener('change', function(){ var e=document.getElementById('fEdad'); if(e) e.value=calcEdad(this.value); });

  // Buscar con Enter
  var bi = document.getElementById('busqInp');
  if(bi) bi.addEventListener('keydown', e=>{ if(e.key==='Enter') buscar(); });

  // Verificar cámara
  var esSeguro = location.protocol==='https:' || location.hostname==='localhost' || location.hostname==='127.0.0.1';
  var tieneAPI = !!(navigator.mediaDevices && navigator.mediaDevices.getUserMedia);
  if(!esSeguro || !tieneAPI){
    var bc = document.getElementById('btnCam');
    var av = document.getElementById('avisCam');
    if(bc) bc.style.display='none';
    if(av){ av.style.display='block'; av.textContent = !esSeguro ? '⚠️ La cámara requiere HTTPS. Usa la opción Galería.' : '⚠️ Tu navegador no soporta cámara. Usa Galería.'; }
  }
});

function leerImagen(file){
  var comprime = file.size > 2*1024*1024;
  var reader = new FileReader();
  reader.onload = function(ev){
    var src = ev.target.result;
    if(comprime){
      var img = new Image();
      img.onload = function(){
        var cv = document.createElement('canvas');
        var MAX=800, ratio=Math.min(MAX/img.width,MAX/img.height,1);
        cv.width=Math.round(img.width*ratio); cv.height=Math.round(img.height*ratio);
        cv.getContext('2d').drawImage(img,0,0,cv.width,cv.height);
        src = cv.toDataURL('image/jpeg',.82);
        guardarFoto(src, 'foto.jpg', 'image/jpeg');
        toast('✓ Imagen optimizada','ok');
      };
      img.src = src;
    } else {
      guardarFoto(src, file.name, file.type);
      toast('✓ Foto cargada','ok');
    }
  };
  reader.readAsDataURL(file);
}

function guardarFoto(dataUrl, nombre, mimeType){
  var b64 = dataUrl.split(',')[1];
  S.fotoB64 = b64;
  S.archivos.foto = { base64:b64, nombre:nombre, mimeType:mimeType };
  var img = document.getElementById('fimg');
  var ph  = document.getElementById('fph');
  var bq  = document.getElementById('btnQFoto');
  if(img){ img.src=dataUrl; img.style.display='block'; }
  if(ph)  ph.style.display='none';
  if(bq)  bq.style.display='block';
}

async function abrirCamara(){
  if(_stream){ detenerCamara(); return; }
  var esSeguro = location.protocol==='https:' || location.hostname==='localhost' || location.hostname==='127.0.0.1';
  if(!esSeguro){ toast('⚠️ La cámara necesita HTTPS. Usa Galería.','err'); return; }
  if(!navigator.mediaDevices||!navigator.mediaDevices.getUserMedia){ toast('Cámara no disponible en este navegador','err'); return; }

  var bc = document.getElementById('btnCam');
  if(bc){ bc.disabled=true; bc.textContent='⏳ Iniciando…'; }

  var configs = [
    {video:{facingMode:'user',width:{ideal:640},height:{ideal:480}}},
    {video:{facingMode:'environment'}},
    {video:true}
  ];
  var ok=false, lastErr=null;
  for(var cfg of configs){
    try{ _stream=await navigator.mediaDevices.getUserMedia(cfg); ok=true; break; }
    catch(e){ lastErr=e; }
  }

  if(!ok){
    if(bc){ bc.disabled=false; bc.textContent='📷 Tomar foto'; }
    var msg = '❌ No se pudo acceder a la cámara.';
    if(lastErr){
      if(lastErr.name==='NotAllowedError') msg='🚫 Permiso denegado. Actívalo en ajustes del navegador.';
      else if(lastErr.name==='NotFoundError') msg='📷 No hay cámara disponible.';
      else if(lastErr.name==='NotReadableError') msg='📷 La cámara está en uso por otra app.';
    }
    toast(msg,'err'); return;
  }

  var vid = document.getElementById('camVid');
  if(!vid) return;
  vid.srcObject = _stream;
  vid.muted = true;
  vid.onloadedmetadata = function(){ vid.play().catch(e=>console.warn('play:',e)); };
  vid.style.display = 'block';

  var cap = document.getElementById('btnCap');
  if(cap) cap.style.display='block';
  if(bc){ bc.style.display='none'; bc.disabled=false; bc.textContent='📷 Tomar foto'; }
}

function capturarFoto(){
  var vid = document.getElementById('camVid');
  var cvs = document.getElementById('camCvs');
  if(!vid||!cvs) return;
  var w=vid.videoWidth||640, h=vid.videoHeight||480;
  cvs.width=w; cvs.height=h;
  cvs.getContext('2d').drawImage(vid,0,0,w,h);
  var dataUrl = cvs.toDataURL('image/jpeg',.85);
  if(!dataUrl||dataUrl==='data:,'){ toast('No se pudo capturar. Intenta de nuevo.','err'); return; }
  guardarFoto(dataUrl,'foto.jpg','image/jpeg');
  detenerCamara();
  toast('✓ Foto capturada','ok');
}

function detenerCamara(){
  if(_stream){ _stream.getTracks().forEach(t=>t.stop()); _stream=null; }
  var vid=document.getElementById('camVid');
  var cap=document.getElementById('btnCap');
  var bc=document.getElementById('btnCam');
  if(vid){ vid.srcObject=null; vid.style.display='none'; }
  if(cap) cap.style.display='none';
  if(bc){ bc.style.display='block'; bc.textContent='📷 Tomar foto'; }
}

function quitarFoto(){
  S.fotoB64=null; delete S.archivos.foto;
  var img=document.getElementById('fimg'),ph=document.getElementById('fph'),bq=document.getElementById('btnQFoto'),inp=document.getElementById('inpGaleria');
  if(img){ img.style.display='none'; img.src=''; }
  if(ph) ph.style.display='block';
  if(bq) bq.style.display='none';
  if(inp) inp.value='';
}

// ══ DOCUMENTOS ═══════════════════════════════════════════════════
function onDoc(event, campo, zoneId, nameId){
  var file = event.target.files && event.target.files[0];
  if(!file) return;
  var reader = new FileReader();
  reader.onload = function(ev){
    S.archivos[campo] = { base64:ev.target.result.split(',')[1], nombre:file.name, mimeType:file.type };
    var nm=document.getElementById(nameId); if(nm) nm.textContent='✓ '+file.name;
    var zn=document.getElementById(zoneId); if(zn) zn.style.borderColor='var(--ok)';
  };
  reader.readAsDataURL(file);
}

// ══ STEPS ════════════════════════════════════════════════════════
function nextStep(n){
  if(!validarStep(n)) return;
  S.step = n+1;
  mostrarStep(S.step);
  if(S.step===4) renderResumen();
}
function prevStep(n){ S.step=n-1; mostrarStep(S.step); }

function mostrarStep(n){
  document.querySelectorAll('.fstep').forEach((el,i)=>el.style.display=(i+1===n)?'block':'none');
  document.querySelectorAll('.step').forEach((el,i)=>{
    var num=i+1;
    el.classList.remove('on','done');
    if(num<n) el.classList.add('done');
    if(num===n) el.classList.add('on');
  });
  window.scrollTo({top:0,behavior:'smooth'});
}

function validarStep(n){
  function g(id){ var e=document.getElementById(id); return e?e.value.trim():''; }
  if(n===1){
    if(!g('fNombre')){ toast('El nombre es requerido','err'); return false; }
    if(!g('fFechaNac')){ toast('La fecha de nacimiento es requerida','err'); return false; }
    if(!g('fSexo')){ toast('Selecciona el sexo','err'); return false; }
  }
  if(n===2){
    if(!g('fMadre')){ toast('Nombre de madre requerido','err'); return false; }
    if(!g('fTel')){ toast('Teléfono requerido','err'); return false; }
    if(!g('fCurso')){ toast('Selecciona el curso','err'); return false; }
  }
  return true;
}

