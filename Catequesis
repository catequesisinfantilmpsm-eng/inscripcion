  var c=ciclo(), hoy=new Date().toLocaleDateString('es-MX',{day:'2-digit',month:'long',year:'numeric'});
  document.getElementById('compContenido').innerHTML=`
    <div class="comp-wrap" id="compPrint">
      ${compMitad(a,c,hoy,'iglesia')}
      <div class="comp-corte"><div class="comp-corte-line"></div>✂ Cortar aquí<div class="comp-corte-line"></div></div>
      ${compMitad(a,c,hoy,'familia')}
    </div>`;
  openMo('moComp');
  setTimeout(()=>{
    ['qrCI','qrCF'].forEach(id=>{
      var el=document.getElementById(id);
      if(el&&a.codigo){ try{ new QRCode(el,{text:a.codigo,width:60,height:60,colorDark:'#000',colorLight:'#fff'}); }catch(e){} }
    });
  },120);
}

function compMitad(a,c,hoy,tipo){
  var esI=tipo==='iglesia';
  var titulo=esI?'📋 Copia Parroquia':'👨‍👩‍👧 Copia Familia';
  var col=esI?'#1a0a2e':'#0d1a40';
  return `<div class="comp-mitad">
    <div class="comp-hdr">
      <div>
        <div class="comp-tit" style="color:${col}">✝ Parroquia — Catequesis</div>
        <div style="font-size:.68rem;color:#777;margin-top:2px">Comprobante de inscripción ${c}</div>
        <div style="display:inline-block;background:${col};color:#f0d070;font-size:.62rem;font-weight:600;padding:2px 8px;border-radius:99px;margin-top:4px">${titulo}</div>
      </div>
      <div style="text-align:right">
        <div id="qrC${esI?'I':'F'}" style="background:#fff;padding:2px;border:1px solid #ddd;border-radius:4px;display:inline-block"></div>
        <div style="font-size:.6rem;color:#aaa;margin-top:2px">${a.codigo||'—'}</div>
      </div>
    </div>
    <table class="comp-table">
      <tr><th>Nombre</th><td colspan="3">${a.nombre}</td></tr>
      <tr><th>Código</th><td>${a.codigo||'—'}</td><th>Fecha</th><td>${hoy}</td></tr>
      <tr><th>Curso</th><td>${a.curso||'—'}</td><th>Grupo</th><td>${a.codigoGrupo||'—'}</td></tr>
      <tr><th>Catequista</th><td>${a.catequista||'—'}</td><th>Día/Hora</th><td>${[a.dia,a.hora].filter(Boolean).join(' ')||'—'}</td></tr>
      <tr><th>Madre</th><td>${a.madre||'—'}</td><th>Teléfono</th><td>${a.telefono||'—'}</td></tr>
      <tr><th>Pago</th><td colspan="3"><b style="color:${a.pago==='Pagado'?'#166534':'#92400e'}">${a.pago||'—'}</b></td></tr>
      <tr><th>Observaciones</th><td colspan="3" style="height:24px"></td></tr>
    </table>
    <div class="comp-firmas">
      <div class="comp-firma">Firma catequista / encargado</div>
      <div class="comp-firma">Firma padre / tutor</div>
    </div>
  </div>`;
}

function imprimirComp(){
  var area=document.getElementById('compPrint');
  if(!area) return;
  var w=window.open('','_blank','width=820,height=700');
  w.document.write(`<!DOCTYPE html><html><head><title>Comprobante</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
    <style>*{box-sizing:border-box;margin:0;padding:0}body{font-family:'DM Sans',sans-serif;padding:16px;background:#fff;color:#111}
    .comp-mitad{padding:14px 18px;min-height:240px}.comp-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
    .comp-tit{font-family:'Cinzel',serif;font-size:.85rem;font-weight:700}.comp-table{width:100%;border-collapse:collapse;font-size:.72rem;margin-bottom:7px}
    .comp-table th{background:#1a0a2e;color:#f0d070;padding:3px 6px;text-align:left;font-size:.64rem}
    .comp-table td{padding:3px 6px;border-bottom:1px solid #eee}
    .comp-firmas{display:flex;gap:18px;margin-top:7px}.comp-firma{flex:1;border-top:1px solid #ccc;padding-top:4px;font-size:.62rem;color:#999;text-align:center}
    .comp-corte{display:flex;align-items:center;gap:8px;padding:3px 0;color:#bbb;font-size:.65rem}
    .comp-corte-line{flex:1;border-top:2px dashed #ccc}
    @page{size:letter portrait;margin:10mm}@media print{body{padding:0}}</style>
    </head><body onload="window.print()">${area.innerHTML}</body></html>`);
  w.document.close();
}

