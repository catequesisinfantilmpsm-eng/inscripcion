  var c=ciclo(), hoy=new Date().toLocaleDateString('es-MX');
  var filas=data.map(a=>`<tr>
    <td>${a.codigo||''}</td><td>${a.nombre||''}</td><td>${a.curso||''}</td>
    <td>${a.codigoGrupo||''}</td><td>${a.catequista||''}</td><td>${a.madre||''}</td>
    <td>${a.telefono||''}</td><td>${a.edad||''}</td><td>${a.dia||''} ${a.hora||''}</td>
    <td style="color:${a.pago==='Pagado'?'#166534':'#92400e'};font-weight:600">${a.pago||'—'}</td>
