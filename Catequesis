async function guardarRegistro(){
  var btn=document.getElementById('btnGuardar');
  if(btn) btn.disabled=true;
  try {
    var datos = leerForm();
    showLoad('Subiendo archivos a Drive…');
    var links = await API.subirTodos(S.archivos||{}, 'TEMP');
    showLoad('Guardando en Google Sheets…');
    var payload = Object.assign({},datos,{
      foto:links.foto||'', actaNac:links.actaNac||'',
      boletaBautizo:links.boletaBautizo||'', boletaConf:links.boletaConf||'',
      comprobantePago:links.comprobantePago||''
    });
    var resp = await API.post('nuevo', payload);
    hideLoad();
    if(resp.ok){
      S.alumno = Object.assign({},payload,{codigo:resp.folio,edad:resp.edad});
