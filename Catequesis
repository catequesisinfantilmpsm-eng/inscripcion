<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<meta name="theme-color" content="#1a0a2e"/>
<title>Catequesis — Inscripciones</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
/* ════ VARIABLES ════ */
:root{
  --bg:#0d0820;--sur:#1a1030;--sur2:#241840;--bor:#352a55;
  --gold:#d4a843;--goldl:#f0c96a;--goldd:rgba(212,168,67,.15);
  --txt:#ede8f5;--dim:#9b90b8;--acc:#7c5cbf;
  --ok:#4ade80;--err:#f87171;--warn:#fbbf24;
  --r:14px;--rsm:8px;--sh:0 8px 32px rgba(0,0,0,.5);
  --tr:.22s cubic-bezier(.4,0,.2,1);
  --fd:'Cinzel',serif;--fb:'DM Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--bg);color:var(--txt);min-height:100dvh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 50% at 80% 10%,rgba(124,92,191,.2) 0%,transparent 60%),
             radial-gradient(ellipse 50% 40% at 10% 90%,rgba(212,168,67,.08) 0%,transparent 60%)}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--sur)}::-webkit-scrollbar-thumb{background:var(--bor);border-radius:99px}

/* ════ HEADER ════ */
.hdr{position:sticky;top:0;z-index:100;background:rgba(13,8,32,.9);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--bor);padding:0 16px;display:flex;align-items:center;gap:12px;height:58px}
.logo{font-family:var(--fd);font-size:.95rem;color:var(--gold);letter-spacing:.06em;white-space:nowrap;flex-shrink:0}
.logo small{color:var(--dim);font-size:.65rem;display:block;font-family:var(--fb);letter-spacing:0}
.nav{display:flex;gap:3px;overflow-x:auto;scrollbar-width:none;flex:1}
.nav::-webkit-scrollbar{display:none}
.nb{flex-shrink:0;background:transparent;border:none;cursor:pointer;color:var(--dim);
  font-family:var(--fb);font-size:.78rem;font-weight:500;padding:5px 12px;border-radius:99px;transition:var(--tr);white-space:nowrap}
.nb:hover{color:var(--txt);background:rgba(255,255,255,.06)}
.nb.on{background:var(--goldd);color:var(--gold);border:1px solid rgba(212,168,67,.3)}

/* ════ MAIN ════ */
main{position:relative;z-index:1;padding:20px 14px 88px;max-width:780px;margin:0 auto}
.pg{display:none;animation:fi .3s ease}.pg.on{display:block}
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ════ CARD ════ */
.card{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:20px;margin-bottom:18px;box-shadow:var(--sh)}
.ctit{font-family:var(--fd);font-size:.9rem;font-weight:600;color:var(--gold);letter-spacing:.04em;margin-bottom:16px;display:flex;align-items:center;gap:8px}

/* ════ FORM ════ */
.fg{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:480px){.fg{grid-template-columns:1fr}}
.full{grid-column:1/-1}
.fld{display:flex;flex-direction:column;gap:5px}
.fld label{font-size:.72rem;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:.05em}
.fld label .rq{color:var(--gold);margin-left:2px}
.fld input,.fld select,.fld textarea{
  background:var(--sur2);border:1px solid var(--bor);border-radius:var(--rsm);
  color:var(--txt);font-family:var(--fb);font-size:.88rem;padding:10px 13px;
  transition:var(--tr);width:100%;-webkit-appearance:none;appearance:none}
.fld input:focus,.fld select:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(212,168,67,.12)}
.fld input[readonly]{opacity:.55;cursor:not-allowed}
select option{background:var(--sur2)}

/* ════ UPLOAD ZONE ════ */
.uz{border:2px dashed var(--bor);border-radius:var(--rsm);padding:16px;text-align:center;cursor:pointer;
  transition:var(--tr);position:relative;overflow:hidden}
.uz:hover{border-color:var(--gold);background:var(--goldd)}
.uz input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.uz .uzi{font-size:1.6rem;margin-bottom:4px}
.uz .uzl{font-size:.78rem;color:var(--dim)}
.uz .uzn{font-size:.74rem;color:var(--ok);margin-top:6px;font-weight:500}

/* ════ FOTO CREDENCIAL ════ */
.fcred{display:flex;gap:14px;align-items:flex-start;flex-wrap:wrap;margin-bottom:14px}
.fprev{width:90px;height:110px;border-radius:var(--rsm);background:var(--sur2);
  border:2px dashed var(--bor);object-fit:cover;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:1.8rem;overflow:hidden}
.fprev img{width:100%;height:100%;object-fit:cover}
.fbtns{display:flex;flex-direction:column;gap:7px;flex:1;min-width:120px}
#camara-video{width:100%;border-radius:var(--rsm);max-height:240px;object-fit:cover;
  border:2px solid var(--gold);display:none;margin-top:10px}
.aviso-cam{display:none;font-size:.78rem;color:var(--warn);background:rgba(251,191,36,.1);
  border:1px solid rgba(251,191,36,.3);border-radius:var(--rsm);padding:8px 12px;margin-top:8px}

/* ════ BOTONES ════ */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border:none;cursor:pointer;
  font-family:var(--fb);font-weight:500;border-radius:var(--rsm);padding:10px 20px;font-size:.85rem;
  transition:var(--tr);white-space:nowrap;text-decoration:none}
.bp{background:linear-gradient(135deg,var(--gold),var(--goldl));color:#1a0a2e;font-weight:700}
.bp:hover{filter:brightness(1.1);transform:translateY(-1px);box-shadow:0 0 20px rgba(212,168,67,.25)}
.bs{background:var(--sur2);color:var(--txt);border:1px solid var(--bor)}
.bs:hover{border-color:var(--acc);color:#a07de0}
.bg{background:transparent;color:var(--dim);border:1px solid var(--bor)}
.bg:hover{color:var(--txt);border-color:var(--dim)}
.bsm{padding:7px 13px;font-size:.78rem}
.bfu{width:100%}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}

/* ════ BADGES ════ */
.badge{display:inline-block;padding:3px 9px;border-radius:99px;font-size:.7rem;font-weight:600}
.bok{background:rgba(74,222,128,.15);color:var(--ok)}
.bwarn{background:rgba(251,191,36,.15);color:var(--warn)}
.berr{background:rgba(248,113,113,.15);color:var(--err)}
.bdim{background:rgba(255,255,255,.07);color:var(--dim)}

/* ════ STEPS ════ */
.steps{display:flex;align-items:center;margin-bottom:20px}
.step{display:flex;align-items:center;flex:1}
.sc{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:.72rem;font-weight:700;flex-shrink:0;border:2px solid var(--bor);
  background:var(--sur2);color:var(--dim);transition:var(--tr)}
.sl{flex:1;height:2px;background:var(--bor);transition:var(--tr)}
.step.done .sc{background:var(--gold);color:#1a0a2e;border-color:var(--gold)}
.step.done .sl{background:var(--gold)}
.step.on .sc{border-color:var(--gold);color:var(--gold)}

/* ════ HERO ════ */
.hero{text-align:center;padding:32px 0 20px}
.hero-sym{font-size:3rem;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
.hero-t{font-family:var(--fd);font-size:clamp(1.3rem,5vw,1.9rem);color:var(--gold);letter-spacing:.05em;margin-bottom:6px}
.hero-s{color:var(--dim);font-size:.88rem;margin-bottom:28px}
.agrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:360px){.agrid{grid-template-columns:1fr}}
.acard{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:20px 14px;
  text-align:center;cursor:pointer;transition:var(--tr)}
.acard:hover{border-color:var(--gold);background:var(--sur2);transform:translateY(-3px);box-shadow:0 0 20px rgba(212,168,67,.15)}
.aci{font-size:1.8rem;margin-bottom:8px}
.acl{font-weight:600;font-size:.85rem}
.acd{font-size:.73rem;color:var(--dim);margin-top:3px}

/* ════ STATS ════ */
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:18px}
.sc2{background:var(--sur2);border:1px solid var(--bor);border-radius:var(--rsm);padding:16px;text-align:center}
.sn{font-family:var(--fd);font-size:1.9rem;color:var(--gold);line-height:1}
.sl2{font-size:.72rem;color:var(--dim);margin-top:5px}

/* ════ TABLE ════ */
.twrap{overflow-x:auto;border-radius:var(--rsm)}
table{width:100%;border-collapse:collapse;font-size:.8rem}
thead{background:var(--sur2)}
th{text-align:left;padding:9px 12px;font-size:.68rem;font-weight:700;color:var(--dim);
  text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--bor);white-space:nowrap}
td{padding:10px 12px;border-bottom:1px solid rgba(53,42,85,.4);vertical-align:middle}
tr:hover td{background:rgba(255,255,255,.025)}
tr:last-child td{border-bottom:none}
.av{width:32px;height:38px;border-radius:4px;object-fit:cover;background:var(--sur2);border:1px solid var(--bor)}

/* ════ TOOLBAR ADMIN ════ */
.atbar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center}
.asi{flex:1;min-width:150px;background:var(--sur2);border:1px solid var(--bor);
  border-radius:var(--rsm);color:var(--txt);font-family:var(--fb);font-size:.85rem;padding:8px 12px}
.asi:focus{outline:none;border-color:var(--gold)}

/* ════ QR RESULT ════ */
.qrbox{background:var(--sur2);border:1px solid var(--gold);border-radius:var(--rsm);
  padding:14px;margin-top:14px;display:none}
.qrbox.on{display:block;animation:fi .3s ease}

/* ════ DIVIDER ════ */
.div{display:flex;align-items:center;gap:10px;color:var(--dim);font-size:.76rem;margin:18px 0}
.div::before,.div::after{content:'';flex:1;height:1px;background:var(--bor)}

/* ════ TOAST ════ */
#tc{position:fixed;bottom:72px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:7px}
.toast{padding:11px 16px;border-radius:var(--rsm);font-size:.83rem;font-weight:500;
  box-shadow:var(--sh);min-width:200px;max-width:300px;animation:si .3s ease}
@keyframes si{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:none}}
.tok{background:#052e16;border:1px solid #166534;color:var(--ok)}
.terr{background:#450a0a;border:1px solid #991b1b;color:var(--err)}
.tinf{background:#1e1b4b;border:1px solid #3730a3;color:#a5b4fc}

/* ════ LOADER ════ */
#loader{position:fixed;inset:0;z-index:9000;background:rgba(13,8,32,.88);
  backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;
  flex-direction:column;gap:14px}
#loader.on{display:flex}
.spin{width:44px;height:44px;border-radius:50%;border:3px solid var(--bor);
  border-top-color:var(--gold);animation:sp .8s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
#lmsg{color:var(--dim);font-size:.85rem}

/* ════ MODAL ════ */
.mo{position:fixed;inset:0;z-index:8000;background:rgba(0,0,0,.75);
  backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:16px}
.mo.on{display:flex}
.mb{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);
  padding:24px;max-width:580px;width:100%;max-height:90dvh;overflow-y:auto;box-shadow:var(--sh);animation:fi .25s ease}
.mh{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.mh h2{font-family:var(--fd);color:var(--gold);font-size:.95rem}
.mcls{background:none;border:none;color:var(--dim);font-size:1.4rem;cursor:pointer;padding:4px;line-height:1}
.mcls:hover{color:var(--txt)}

/* ════ BOTTOM TABS ════ */
.btabs{display:none;position:fixed;bottom:0;left:0;right:0;z-index:200;
  background:rgba(13,8,32,.97);backdrop-filter:blur(16px);
  border-top:1px solid var(--bor);padding:5px 0 env(safe-area-inset-bottom);
  justify-content:space-around}
@media(max-width:560px){.btabs{display:flex}.nav{display:none}}
.bt{display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:none;
  cursor:pointer;color:var(--dim);font-family:var(--fb);font-size:.6rem;font-weight:500;
  padding:5px 8px;border-radius:8px;transition:var(--tr);min-width:50px}
.bti{font-size:1.25rem;line-height:1}
.bt.on{color:var(--gold)}
.bt.on .bti{filter:drop-shadow(0 0 4px var(--gold))}

/* ════ CREDENCIAL PRINT ════ */
.cred-wrap{font-family:'DM Sans',sans-serif;background:linear-gradient(145deg,#1a0a2e,#0d1a40);
  border:2px solid #c8a84b;border-radius:12px;overflow:hidden;width:320px;margin:0 auto}
.cred-hdr{background:linear-gradient(90deg,#c8a84b,#f0d070,#c8a84b);padding:7px 14px;text-align:center}
.cred-hdr span{font-family:'Cinzel',serif;font-size:.6rem;font-weight:700;color:#1a0a2e;letter-spacing:.1em;text-transform:uppercase}
.cred-body{padding:14px;display:flex;gap:12px;align-items:flex-start}
.cred-foto{width:84px;height:100px;border-radius:6px;border:2px solid #c8a84b;object-fit:cover;
  background:#2a1f50;display:flex;align-items:center;justify-content:center;font-size:1.8rem;flex-shrink:0;overflow:hidden}
.cred-foto img{width:100%;height:100%;object-fit:cover}
.cred-info{flex:1;min-width:0}
.cred-name{font-family:'Cinzel',serif;font-size:.92rem;font-weight:700;color:#f0d070;margin-bottom:7px;line-height:1.2}
.cred-row{display:flex;gap:5px;font-size:.68rem;margin-bottom:3px}
.cred-lbl{color:rgba(240,215,112,.55);min-width:65px}
.cred-val{color:#ede8f5;font-weight:500}
.cred-qr{margin-top:7px;background:#fff;padding:3px;border-radius:4px;display:inline-block}
.cred-ftr{background:rgba(200,168,75,.1);border-top:1px solid rgba(200,168,75,.25);
  padding:5px 14px;text-align:center;font-size:.58rem;color:rgba(240,215,112,.5)}

/* ════ COMPROBANTE PRINT ════ */
.comp-wrap{font-family:'DM Sans',sans-serif;background:#fff;color:#111}
.comp-mitad{padding:16px 20px;min-height:260px}
.comp-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.comp-tit{font-family:'Cinzel',serif;font-size:.88rem;font-weight:700}
.comp-table{width:100%;border-collapse:collapse;font-size:.75rem;margin-bottom:8px}
.comp-table th{background:#1a0a2e;color:#f0d070;padding:4px 7px;text-align:left;font-size:.67rem}
.comp-table td{padding:4px 7px;border-bottom:1px solid #eee;vertical-align:top}
.comp-firmas{display:flex;gap:20px;margin-top:8px}
.comp-firma{flex:1;border-top:1px solid #ccc;padding-top:5px;font-size:.64rem;color:#999;text-align:center}
.comp-corte{display:flex;align-items:center;gap:8px;padding:3px 0;color:#bbb;font-size:.68rem}
.comp-corte-line{flex:1;border-top:2px dashed #ccc}

@media print{
  body{background:#fff;color:#000}
  .hdr,.btabs,#tc,#loader,.no-print{display:none!important}
  main{padding:0;max-width:100%}
  .pg{display:block!important}
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="hdr">
  <div class="logo">✝ Catequesis<small>Sistema de inscripción</small></div>
  <nav class="nav" id="navTabs">
    <button class="nb on" data-pg="inicio">🏠 Inicio</button>
    <button class="nb" data-pg="registro">📋 Registro</button>
    <button class="nb" data-pg="qr">📷 QR</button>
    <button class="nb" data-pg="buscar">🔍 Buscar</button>
    <button class="nb" data-pg="admin">⚙️ Admin</button>
  </nav>
</header>

<!-- LOADER -->
<div id="loader"><div class="spin"></div><div id="lmsg">Procesando…</div></div>
<!-- TOASTS -->
<div id="tc"></div>

<main>

<!-- ═══════════ INICIO ═══════════ -->
<section class="pg on" id="pg-inicio">
  <div class="hero">
    <div class="hero-sym">✝</div>
    <h1 class="hero-t">Parroquia — Catequesis</h1>
    <p class="hero-s">Sistema de gestión de inscripciones</p>
  </div>
  <div class="agrid">
    <div class="acard" onclick="goPage('registro')"><div class="aci">📋</div><div class="acl">Nueva inscripción</div><div class="acd">Registrar nuevo alumno</div></div>
    <div class="acard" onclick="goPage('qr')"><div class="aci">📷</div><div class="acl">Escanear QR</div><div class="acd">Renovar inscripción</div></div>
    <div class="acard" onclick="goPage('buscar')"><div class="aci">🔍</div><div class="acl">Buscar alumno</div><div class="acd">Nombre, teléfono o código</div></div>
    <div class="acard" onclick="goPage('admin')"><div class="aci">⚙️</div><div class="acl">Panel admin</div><div class="acd">Dashboard y exportación</div></div>
  </div>
  <div class="div">Resumen del ciclo</div>
  <div class="sgrid">
    <div class="sc2"><div class="sn" id="sTotal">—</div><div class="sl2">Inscritos</div></div>
    <div class="sc2"><div class="sn" id="sPagados">—</div><div class="sl2">Con pago</div></div>
    <div class="sc2"><div class="sn" id="sPend">—</div><div class="sl2">Pendientes</div></div>
    <div class="sc2"><div class="sn" id="sGrupos">—</div><div class="sl2">Grupos</div></div>
  </div>
</section>

<!-- ═══════════ REGISTRO ═══════════ -->
<section class="pg" id="pg-registro">

  <div class="steps" id="formSteps">
    <div class="step on" data-s="1"><div class="sc">1</div><div class="sl"></div></div>
    <div class="step" data-s="2"><div class="sc">2</div><div class="sl"></div></div>
    <div class="step" data-s="3"><div class="sc">3</div><div class="sl"></div></div>
    <div class="step" data-s="4"><div class="sc">4</div></div>
  </div>

  <form id="formReg" novalidate autocomplete="off">

    <!-- PASO 1 -->
    <div class="fstep" id="fs1">
      <div class="card">
        <div class="ctit">👤 Datos del alumno</div>

        <div class="fcred">
          <div class="fprev" id="fprev"><span id="fph">📷</span><img id="fimg" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover"/></div>
          <div class="fbtns">
            <button type="button" class="btn bs bsm" id="btnCam" onclick="abrirCamara()">📷 Tomar foto</button>
            <label class="btn bg bsm" style="cursor:pointer">
              🖼 Galería
              <input type="file" accept="image/*" id="inpGaleria" style="position:absolute;opacity:0;width:0;height:0"/>
            </label>
            <button type="button" class="btn bg bsm" id="btnQFoto" style="display:none" onclick="quitarFoto()">✕ Quitar</button>
          </div>
        </div>
        <div class="aviso-cam" id="avisCam"></div>
        <video id="camVid" autoplay playsinline muted></video>
        <canvas id="camCvs" style="display:none"></canvas>
        <button type="button" class="btn bp bsm" id="btnCap" style="display:none;margin-top:8px" onclick="capturarFoto()">✓ Capturar foto</button>

        <div class="fg" style="margin-top:14px">
          <div class="fld full"><label>Nombre completo <span class="rq">*</span></label>
            <input type="text" id="fNombre" placeholder="Apellidos Nombre" autocomplete="name"/></div>
          <div class="fld"><label>Fecha de nacimiento <span class="rq">*</span></label>
            <input type="date" id="fFechaNac"/></div>
          <div class="fld"><label>Edad (automática)</label>
            <input type="text" id="fEdad" readonly placeholder="Auto"/></div>
          <div class="fld"><label>Sexo <span class="rq">*</span></label>
            <select id="fSexo"><option value="">— Seleccionar —</option><option>Masculino</option><option>Femenino</option></select></div>
          <div class="fld"><label>Talla</label>
            <select id="fTalla"><option value="">— Seleccionar —</option>
              <option>6</option><option>8</option><option>10</option><option>12</option><option>14</option><option>16</option>
              <option>adulto S</option><option>adulto M</option><option>adulto L</option><option>adulto XL</option></select></div>
        </div>
      </div>
      <div style="display:flex;justify-content:flex-end"><button type="button" class="btn bp" onclick="nextStep(1)">Siguiente →</button></div>
    </div>

    <!-- PASO 2 -->
    <div class="fstep" id="fs2" style="display:none">
