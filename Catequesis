var _allReg=[], _filtReg=[];

async function cargarAdmin(){
  showLoad('Cargando registros…');
  var resp=await API.get('todos');
  hideLoad();
  if(!resp.ok){ toast('Error: '+(resp.msg||''),'err'); return; }
  _allReg=resp.datos||[];
  S.registros=_allReg;
  _filtReg=_allReg;
  actualizarStats(_allReg);
  poblarFiltros();
  renderTabla(_allReg);
  toast('✓ '+_allReg.length+' registros cargados','ok');
}

function actualizarStats(data){
  var tot=data.length, pag=data.filter(r=>r.pago==='Pagado').length,
      pen=data.filter(r=>r.pago==='Pendiente').length,
      grp=[...new Set(data.map(r=>r.codigoGrupo).filter(Boolean))].length;
  ['sTotal','asTotal'].forEach(id=>{ var e=document.getElementById(id); if(e) e.textContent=tot; });
  ['sPagados','asPagados'].forEach(id=>{ var e=document.getElementById(id); if(e) e.textContent=pag; });
  ['sPend','asPend'].forEach(id=>{ var e=document.getElementById(id); if(e) e.textContent=pen; });
  ['sGrupos','asGrupos'].forEach(id=>{ var e=document.getElementById(id); if(e) e.textContent=grp; });
}

function poblarFiltros(){
  var grupos=[...new Set(_allReg.map(r=>r.codigoGrupo).filter(Boolean))].sort();
  var sel=document.getElementById('fGrupo');
  while(sel.options.length>1) sel.remove(1);
  grupos.forEach(g=>{ var o=document.createElement('option'); o.value=g; o.textContent=g; sel.appendChild(o); });
}

function filtrarAdmin(){
  var q=document.getElementById('adminSrch').value.toLowerCase();
  var gr=document.getElementById('fGrupo').value;
  var cu=document.getElementById('fCursoF').value;
  var pa=document.getElementById('fPagoF').value;
  _filtReg=_allReg.filter(r=>{
    var mb=!q||r.nombre.toLowerCase().includes(q)||r.codigo.toLowerCase().includes(q)||(r.telefono||'').includes(q);
    var mg=!gr||r.codigoGrupo===gr;
    var mc=!cu||r.curso===cu;
    var mp=!pa||r.pago===pa;
    return mb&&mg&&mc&&mp;
  });
  renderTabla(_filtReg);
}

